{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Tools History Archive Record",
  "type": "object",
  "required": [
    "id",
    "slug",
    "name",
    "entity_type",
    "category",
    "operator",
    "status",
    "current_state",
    "summary",
    "confidence",
    "events",
    "evidence",
    "last_reviewed_at"
  ],
  "properties": {
    "id": { "type": "string" },
    "slug": { "type": "string" },
    "name": { "type": "string" },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "entity_type": { "type": "string" },
    "category": { "type": "array", "items": { "type": "string" } },
    "operator": { "type": "string" },
    "country": { "type": ["string", "null"] },
    "status": { "type": "string" },
    "current_state": { "type": "string" },
    "launched_at": { "type": ["string", "null"] },
    "ended_at": { "type": ["string", "null"] },
    "last_known_url": { "type": ["string", "null"] },
    "current_url_status": { "type": "string" },
    "summary": { "type": "string" },
    "confidence": { "type": "string" },
    "related_records": { "type": "array", "items": { "type": "string" } },
    "last_reviewed_at": { "type": "string" },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "date", "type", "title", "description", "evidence_ids", "confidence"],
        "properties": {
          "id": { "type": "string" },
          "date": { "type": "string" },
          "type": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "evidence_ids": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "url", "source_type", "accessed_at", "supports", "reliability"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "url": { "type": "string" },
          "archived_url": { "type": "string" },
          "source_type": { "type": "string" },
          "accessed_at": { "type": "string" },
          "supports": { "type": "array", "items": { "type": "string" } },
          "reliability": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
